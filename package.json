{
  "name": "easylaskutus",
  "version": "1.0.0",
  "description": "EasyLaskutus desktop app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "dist:win": "electron-builder --win portable nsis --publish never",
    "dist:linux": "electron-builder --linux AppImage deb --publish never",
    "dist:mac": "electron-builder --mac dmg zip --publish never",
    "dist": "electron-builder --win portable nsis --linux AppImage deb --mac dmg zip --publish never"
  },
  "keywords": [],
  "author": "Valter Backström",
  "email": "walter@wbservice.fi",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "fi.easylaskutus.app",
    "productName": "EasyLaskutus",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "renderer.js",
      "index.html",
      "style.css",
      "database.js",
      "package.json",
      "laskutus.db",
      "build/**/*"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Office",
      "maintainer": "Valter Backström <walter@wbservice.fi>"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity"
    }
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "bwip-js": "^4.9.0",
    "pdfkit": "^0.18.0",
    "sqlite3": "^6.0.1"
  }
}